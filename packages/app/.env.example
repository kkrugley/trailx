# Bot REST/WebSocket base URL (e.g. https://your-bot.railway.app)
# GraphHopper routing is proxied through the bot backend — no API key needed here
VITE_API_URL=http://localhost:3001
VITE_BOT_WS_URL=http://localhost:3001

# Mapillary token for POI street-level imagery (optional)
VITE_MAPILLARY_TOKEN=
