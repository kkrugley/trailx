generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id            String   @id
  chatId        BigInt   @unique
  isPro         Boolean  @default(false)
  activeRouteId String?
  createdAt     DateTime @default(now())
  routes        Route[]
}

model Route {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  name      String?
  waypoints Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  chatId    BigInt   @unique
  userId    BigInt
  status    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PendingVote {
  id        String   @id @default(cuid())
  pollId    String   @unique
  chatId    BigInt
  place     String
  routeId   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
}
