# GraphHopper API key (optional — free tier: 500 req/day without key)
VITE_GRAPHHOPPER_API_KEY=

# Bot REST/WebSocket base URL (e.g. https://your-bot.railway.app)
VITE_API_URL=http://localhost:3000
VITE_BOT_WS_URL=http://localhost:3000

# Mapillary token for POI street-level imagery (optional)
VITE_MAPILLARY_TOKEN=
